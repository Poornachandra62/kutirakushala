<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.KutiraKushala" parent="Theme.MaterialComponents.Light.DarkActionBar">
        <item name="colorPrimary">@color/primary_green</item>
        <item name="colorPrimaryVariant">@color/primary_green_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/accent_orange</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:colorBackground">@color/bg_cream</item>
        <item name="android:windowBackground">@color/bg_cream</item>
        <item name="android:statusBarColor">@color/primary_green_dark</item>
        <item name="actionBarStyle">@style/KutiraActionBar</item>
    </style>

    <style name="KutiraActionBar" parent="Widget.AppCompat.ActionBar.Solid">
        <item name="background">@color/primary_green</item>
        <item name="titleTextStyle">@style/KutiraActionBarTitle</item>
    </style>

    <style name="KutiraActionBarTitle" parent="TextAppearance.AppCompat.Widget.ActionBar.Title">
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>
